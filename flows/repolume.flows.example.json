{
  "_comment": "Copy this file to repolume.flows.json and adjust tool names and scope to your environment.",
  "mcpInstances": [
    {
      "instanceName": "oracle-orders",
      "tool": "oracle",
      "roles": ["db-schema", "db-stored-proc", "db-query"],
      "scope": {
        "databases": ["ORDERS"],
        "description": "Oracle order schema"
      }
    },
    {
      "instanceName": "sqlserver-notifications",
      "tool": "devdb",
      "roles": ["db-schema"],
      "scope": {
        "databases": ["notifications"],
        "description": "SQL Server notification database"
      }
    },
    {
      "instanceName": "github-enterprise",
      "tool": "github",
      "roles": ["code-reader"],
      "scope": {
        "host": "github.example.com",
        "description": "Example GitHub Enterprise instance"
      }
    }
  ]
}
